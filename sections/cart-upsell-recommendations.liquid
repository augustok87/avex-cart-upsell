{{ 'cart-upsell.css' | asset_url | stylesheet_tag }}
<script src="{{ 'cart-upsell.js' | asset_url }}" defer="defer"></script>

{%- if cart.item_count > 0 -%}
  <cart-upsell
    class="cart-upsell page-width"
    data-product-id="{{ cart.items.first.product_id }}"
    data-cart-product-ids="{%- for item in cart.items -%}{{ item.product_id }}{%- unless forloop.last -%},{%- endunless -%}{%- endfor -%}"
    data-limit="{{ section.settings.products_to_show }}"
  >
    {%- if section.settings.heading != blank -%}
      <h2 class="cart-upsell__heading {{ section.settings.heading_size }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    <div class="cart-upsell__grid" data-upsell-grid role="list" aria-label="{{ section.settings.heading | escape }}"></div>

    <p class="cart-upsell__empty" data-upsell-empty hidden>
      {{ section.settings.empty_text | escape }}
    </p>

    <div class="cart-upsell__loading" data-upsell-loading hidden aria-hidden="true">
      <svg class="cart-upsell__spinner" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2" stroke-dasharray="31.4 31.4" />
      </svg>
    </div>
  </cart-upsell>
{%- endif -%}

{% schema %}
{
  "name": "Cart Upsell",
  "tag": "section",
  "class": "section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You may also like"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "options": [
        { "value": "h3", "label": "Small" },
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ],
      "default": "h2"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty state text",
      "default": "No recommendations available"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Cart Upsell"
    }
  ]
}
{% endschema %}
